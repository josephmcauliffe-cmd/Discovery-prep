# --- App Logic ---

def generate_meddicc_report(company, url, linkedin_list, notes):
    """Calls Gemini API to generate the research report"""
    model = genai.GenerativeModel(
        model_name="gemini-2.5-flash-preview-09-2025",
        system_instruction="""You are an expert Enterprise Sales Consultant specializing in the MEDDICC framework and Unqork's Codeless Platform. 
        Your task is to conduct deep research on a target company and its stakeholders to prepare a discovery brief specifically positioned for Unqork.
        
        UNQORK VALUE PROPOSITION:
        - Eliminating technical debt by removing code.
        - Accelerating time-to-market for complex enterprise apps.
        - Future-proofing with "Codeless as a Managed Service".
        
        Deliver the output in a structured format with deep insights, research hypotheses, and Unqork-specific discovery questions."""
    )
    
    prompt = f"""
    COMPANY: {company}
    WEBSITE: {url}
    STAKEHOLDERS: {', '.join(linkedin_list)}
    MEETING CONTEXT: {notes}

    Provide a MEDDICC report with:
    1. Company Context & Strategic Goals.
    2. Stakeholder Motivations for the call.
    3. The 'Unqork Angle' (Why Unqork, Why Now).
    4. Strategic Discovery Questions.
    """
    
    # Using tools for search grounding
    response = model.generate_content(prompt, tools=[{'google_search': {}}])
    return response.text

# --- Views ---

if page == "New Prep Doc":
    st.header("Research New Prospect")
    
    col1, col2 = st.columns(2)
    with col1:
        company_name = st.text_input("Company Name", placeholder="e.g. Goldman Sachs")
    with col2:
        company_url = st.text_input("Website URL", placeholder="company.com")
        
    st.subheader("Stakeholders")
    # Dynamic list for LinkedIn URLs
    if 'links' not in st.session_state:
        st.session_state.links = [""]
    
    for i, link in enumerate(st.session_state.links):
        st.session_state.links[i] = st.text_input(f"LinkedIn URL {i+1}", value=link, key=f"li_{i}")
        
    if st.button("+ Add Stakeholder"):
        st.session_state.links.append("")
        st.rerun()

    st.subheader("Context & Notes")
    notes = st.text_area("Additional Notes", placeholder="What do you already know?", height=150)

    if st.button("Generate Unqork Prep Doc"):
        if not company_name:
            st.error("Please enter a company name.")
        else:
            with st.spinner("Conducting deep research..."):
                try:
                    report = generate_meddicc_report(company_name, company_url, st.session_state.links, notes)
                    st.success("Report Generated!")
                    st.markdown("---")
                    st.markdown(report)
                    
                    # Store in session state for 'Dashboard' simulation
                    if 'reports' not in st.session_state:
                        st.session_state.reports = []
                    
                    st.session_state.reports.append({
                        "id": str(uuid.uuid4()),
                        "company": company_name,
                        "date": datetime.now().strftime("%Y-%m-%d"),
                        "content": report
                    })
                except Exception as e:
                    st.error(f"Error: {str(e)}")

elif page == "Dashboard":
    st.header("Discovery Briefs")
    
    if 'reports' not in st.session_state or not st.session_state.reports:
        st.write("No reports generated yet.")
    else:
        for report in reversed(st.session_state.reports):
            with st.expander(f"{report['company']} - {report['date']}"):
                st.markdown(report['content'])
                if st.button(f"Delete {report['id']}", key=report['id']):
                    st.session_state.reports = [r for r in st.session_state.reports if r['id'] != report['id']]
                    st.rerun()
