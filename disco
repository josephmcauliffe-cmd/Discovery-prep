import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from 'firebase/auth';
import { getFirestore, collection, addDoc, onSnapshot, query, doc, deleteDoc } from 'firebase/firestore';
import { 
  Building2, 
  Linkedin, 
  FileText, 
  Search, 
  ChevronRight, 
  Target, 
  Users, 
  Clock, 
  Trash2,
  Loader2,
  Sparkles,
  ExternalLink,
  CheckCircle2,
  Zap,
  Globe,
  Plus
} from 'lucide-react';

// --- Firebase Configuration & Initialization ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'discovery-call-prep-app';
const apiKey = ""; // Environment provides this

const App = () => {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(false);
  const [reports, setReports] = useState([]);
  const [currentView, setCurrentView] = useState('dashboard'); // dashboard, new, report
  const [activeReport, setActiveReport] = useState(null);

  // Form State
  const [companyName, setCompanyName] = useState('');
  const [companyUrl, setCompanyUrl] = useState('');
  const [linkedinUrls, setLinkedinUrls] = useState(['']);
  const [meetingNotes, setMeetingNotes] = useState('');

  // --- Auth & Data Fetching ---
  useEffect(() => {
    const initAuth = async () => {
      if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(auth, __initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    };
    initAuth();
    const unsubscribeAuth = onAuthStateChanged(auth, (u) => {
      setUser(u);
    });
    return () => unsubscribeAuth();
  }, []);

  useEffect(() => {
    if (!user) return;
    const q = query(collection(db, 'artifacts', appId, 'users', user.uid, 'reports'));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setReports(data.sort((a, b) => b.createdAt - a.createdAt));
    }, (error) => {
      console.error("Firestore error:", error);
    });
    return () => unsubscribe();
  }, [user]);

  // --- Helper Functions ---
  const handleAddLinkedin = () => setLinkedinUrls([...linkedinUrls, '']);
  const handleRemoveLinkedin = (index) => {
    const newUrls = [...linkedinUrls];
    newUrls.splice(index, 1);
    setLinkedinUrls(newUrls);
  };

  const updateLinkedinUrl = (index, value) => {
    const newUrls = [...linkedinUrls];
    newUrls[index] = value;
    setLinkedinUrls(newUrls);
  };

  // --- Gemini API Logic ---
  const generateReport = async () => {
    setLoading(true);
    const systemPrompt = `You are an expert Enterprise Sales Consultant specializing in the MEDDICC framework and Unqork's Codeless Platform. 
    Your task is to conduct deep research on a target company and its stakeholders to prepare a discovery brief specifically positioned for Unqork.
    
    UNQORK VALUE PROPOSITION:
    - Eliminating technical debt by removing code.
    - Accelerating time-to-market for complex enterprise apps.
    - Future-proofing with "Codeless as a Managed Service".
    - Security and compliance built into the platform.

    MEDDICC FRAMEWORK:
    - Metrics: ROI through faster dev cycles and reduced maintenance.
    - Economic Buyer: CIO, CTO, or Head of Digital Transformation.
    - Decision Criteria: Speed, scalability, security, cost-reduction.
    - Identify Pain: High maintenance costs, slow dev cycles, legacy code bloat.

    Deliver the output in a structured format with deep insights, research hypotheses, and Unqork-specific discovery questions.`;

    const userQuery = `
      COMPANY: ${companyName}
      WEBSITE: ${companyUrl}
      STAKEHOLDERS: ${linkedinUrls.join(', ')}
      MEETING CONTEXT: ${meetingNotes}

      1. Research recent company news, earnings calls, or strategic pillars.
      2. Analyze the stakeholder roles and identify what "Pain" they likely face that Unqork solves.
      3. Provide a MEDDICC report with:
         - Company Context: Current tech stack rumors and digital goals.
         - Stakeholder Motivations: How this call helps their specific career/department goals.
         - Unqork Angle: A specific "Why Unqork, Why Now" section for this prospect.
         - Discovery Questions: Tactical questions to uncover pain related to legacy code and slow agility.
      4. Recommendations for the opening "Value Hook" tailored to Unqork.
    `;

    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: userQuery }] }],
          systemInstruction: { parts: [{ text: systemPrompt }] },
          tools: [{ "google_search": {} }]
        })
      });

      const result = await response.json();
      const reportText = result.candidates?.[0]?.content?.parts?.[0]?.text || "Failed to generate report.";
      const sources = result.candidates?.[0]?.groundingMetadata?.groundingAttributions?.map(a => ({ 
        uri: a.web?.uri, 
        title: a.web?.title 
      })) || [];

      const newReport = {
        companyName,
        companyUrl,
        linkedinUrls,
        content: reportText,
        sources: sources,
        createdAt: Date.now(),
        userId: user.uid
      };

      await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'reports'), newReport);
      
      setCompanyName('');
      setCompanyUrl('');
      setLinkedinUrls(['']);
      setMeetingNotes('');
      setCurrentView('dashboard');
    } catch (error) {
      console.error("Error generating report:", error);
    } finally {
      setLoading(false);
    }
  };

  const deleteReport = async (e, id) => {
    e.stopPropagation();
    try {
      await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'reports', id));
    } catch (error) {
      console.error("Delete error:", error);
    }
  };

  // --- UI Components ---

  const InputBox = ({ label, icon: Icon, children, className = "" }) => (
    <div className={`bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow ${className}`}>
      <div className="flex items-center gap-3 mb-4">
        <div className="w-10 h-10 bg-indigo-50 dark:bg-indigo-900/30 rounded-xl flex items-center justify-center text-indigo-600 dark:text-indigo-400">
          <Icon className="w-5 h-5" />
        </div>
        <h3 className="font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wider text-xs">{label}</h3>
      </div>
      {children}
    </div>
  );

  const Dashboard = () => (
    <div className="space-y-8 animate-in fade-in duration-500">
      <div className="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
        <div>
          <h1 className="text-4xl font-black text-slate-900 dark:text-white tracking-tight">Discovery Prep</h1>
          <p className="text-slate-500 dark:text-slate-400 mt-2 text-lg">Deep research for the Unqork sales team.</p>
        </div>
        <button 
          onClick={() => setCurrentView('new')}
          className="flex items-center justify-center gap-2 px-8 py-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl font-bold transition-all shadow-xl shadow-indigo-200 dark:shadow-none hover:scale-[1.02] active:scale-95"
        >
          <Zap className="w-5 h-5 fill-current" />
          Create New Prep Doc
        </button>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reports.length === 0 ? (
          <div className="col-span-full py-24 text-center bg-white dark:bg-slate-900 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-[2rem]">
            <div className="bg-indigo-50 dark:bg-indigo-900/20 w-20 h-20 rounded-3xl flex items-center justify-center mx-auto mb-6">
              <Search className="w-10 h-10 text-indigo-600" />
            </div>
            <h3 className="text-xl font-bold text-slate-900 dark:text-white">Ready to win?</h3>
            <p className="text-slate-500 max-w-sm mx-auto mt-3">Enter a company and stakeholders to generate a research-backed MEDDICC discovery guide.</p>
          </div>
        ) : (
          reports.map(report => (
            <div 
              key={report.id}
              onClick={() => { setActiveReport(report); setCurrentView('report'); }}
              className="group relative bg-white dark:bg-slate-900 p-7 rounded-[2rem] border border-slate-100 dark:border-slate-800 hover:border-indigo-500 dark:hover:border-indigo-500 transition-all cursor-pointer shadow-sm hover:shadow-2xl"
            >
              <button 
                onClick={(e) => deleteReport(e, report.id)}
                className="absolute top-6 right-6 p-2 text-slate-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity"
              >
                <Trash2 className="w-4 h-4" />
              </button>
              <div className="flex items-start gap-4 mb-6">
                <div className="w-14 h-14 bg-indigo-50 dark:bg-indigo-950 rounded-2xl flex items-center justify-center flex-shrink-0 text-indigo-600 dark:text-indigo-400">
                  <Building2 className="w-7 h-7" />
                </div>
                <div className="overflow-hidden">
                  <h3 className="font-bold text-xl text-slate-900 dark:text-white truncate">{report.companyName}</h3>
                  <p className="text-sm text-slate-400 font-medium">{new Date(report.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</p>
                </div>
              </div>
              <div className="flex flex-wrap gap-2 mb-6">
                <span className="px-3 py-1 bg-indigo-50 dark:bg-indigo-900/30 text-[11px] font-bold text-indigo-600 dark:text-indigo-400 rounded-full uppercase">Unqork Angle</span>
                <span className="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-[11px] font-bold text-slate-600 dark:text-slate-400 rounded-full uppercase">MEDDICC</span>
              </div>
              <div className="flex items-center text-indigo-600 dark:text-indigo-400 text-sm font-bold pt-4 border-t border-slate-50 dark:border-slate-800">
                Review Research
                <ChevronRight className="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" />
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  );

  const NewReportForm = () => (
    <div className="max-w-4xl mx-auto space-y-10 pb-24 animate-in slide-in-from-bottom-4 duration-500">
      <div className="flex items-center gap-4">
        <button 
          onClick={() => setCurrentView('dashboard')}
          className="p-3 hover:bg-white dark:hover:bg-slate-900 rounded-2xl transition-all shadow-sm"
        >
          <ChevronRight className="w-6 h-6 rotate-180 text-slate-600" />
        </button>
        <h1 className="text-3xl font-black text-slate-900 dark:text-white">Research New Prospect</h1>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        {/* Box 1: Company Name */}
        <InputBox label="Company Name" icon={Building2}>
          <input 
            value={companyName}
            onChange={e => setCompanyName(e.target.value)}
            placeholder="e.g. Goldman Sachs"
            className="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-indigo-500 focus:bg-white dark:focus:bg-slate-700 transition-all outline-none text-lg font-medium"
          />
        </InputBox>

        {/* Box 2: Website URL */}
        <InputBox label="Website URL" icon={Globe}>
          <input 
            value={companyUrl}
            onChange={e => setCompanyUrl(e.target.value)}
            placeholder="company.com"
            className="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-indigo-500 focus:bg-white dark:focus:bg-slate-700 transition-all outline-none text-lg font-medium"
          />
        </InputBox>

        {/* Box 3: LinkedIn Stakeholders */}
        <InputBox label="LinkedIn Stakeholders" icon={Linkedin} className="md:col-span-2">
          <div className="space-y-4">
            {linkedinUrls.map((url, idx) => (
              <div key={idx} className="flex gap-3 group">
                <input 
                  value={url}
                  onChange={e => updateLinkedinUrl(idx, e.target.value)}
                  placeholder="Paste LinkedIn Profile URL"
                  className="flex-1 px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-indigo-500 focus:bg-white dark:focus:bg-slate-700 transition-all outline-none font-medium"
                />
                {linkedinUrls.length > 1 && (
                  <button onClick={() => handleRemoveLinkedin(idx)} className="p-3 text-slate-300 hover:text-red-500 bg-slate-50 dark:bg-slate-800 rounded-xl hover:bg-red-50 transition-colors">
                    <Trash2 className="w-5 h-5" />
                  </button>
                )}
              </div>
            ))}
            <button 
              onClick={handleAddLinkedin}
              className="flex items-center gap-2 text-sm font-bold text-indigo-600 hover:text-indigo-700 transition-colors py-2 px-1"
            >
              <Plus className="w-4 h-4" />
              Add another stakeholder
            </button>
          </div>
        </InputBox>

        {/* Box 4: Additional Notes */}
        <InputBox label="Additional Notes & Context" icon={FileText} className="md:col-span-2">
          <textarea 
            value={meetingNotes}
            onChange={e => setMeetingNotes(e.target.value)}
            rows={5}
            placeholder="What have you learned so far? Any specific goals for this Unqork discovery call?"
            className="w-full px-4 py-4 rounded-xl bg-slate-50 dark:bg-slate-800 border-2 border-transparent focus:border-indigo-500 focus:bg-white dark:focus:bg-slate-700 transition-all outline-none resize-none font-medium text-lg leading-relaxed"
          />
        </InputBox>
      </div>

      <div className="pt-4">
        <button 
          onClick={generateReport}
          disabled={loading || !companyName}
          className="w-full py-6 bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-200 dark:disabled:bg-slate-800 text-white rounded-3xl font-black text-xl transition-all shadow-2xl shadow-indigo-200 dark:shadow-none flex items-center justify-center gap-4 hover:scale-[1.01] active:scale-[0.98]"
        >
          {loading ? (
            <>
              <Loader2 className="w-8 h-8 animate-spin" />
              Running Deep Research...
            </>
          ) : (
            <>
              <Search className="w-7 h-7" />
              Generate Unqork Prep Doc
            </>
          )}
        </button>
      </div>
    </div>
  );

  const ReportView = () => {
    if (!activeReport) return null;
    
    const renderMarkdown = (text) => {
      return text.split('\n').map((line, i) => {
        if (line.startsWith('###')) return <h3 key={i} className="text-xl font-black text-slate-900 dark:text-white mt-10 mb-5">{line.replace('###', '')}</h3>;
        if (line.startsWith('##')) return <h2 key={i} className="text-2xl font-black text-indigo-600 dark:text-indigo-400 mt-12 mb-6 border-b-4 border-indigo-50 dark:border-indigo-900/20 pb-3 inline-block">{line.replace('##', '')}</h2>;
        if (line.startsWith('#')) return <h1 key={i} className="text-4xl font-black text-slate-900 dark:text-white mt-16 mb-10 tracking-tight">{line.replace('#', '')}</h1>;
        if (line.startsWith('-') || line.startsWith('*')) return <li key={i} className="ml-6 mb-3 text-slate-700 dark:text-slate-300 list-none flex items-start gap-3"><div className="w-1.5 h-1.5 bg-indigo-500 rounded-full mt-2.5 flex-shrink-0" /> {line.substring(1).trim()}</li>;
        if (line.trim() === '') return <div key={i} className="h-4" />;
        return <p key={i} className="mb-6 text-slate-700 dark:text-slate-300 leading-relaxed text-lg">{line}</p>;
      });
    };

    return (
      <div className="max-w-4xl mx-auto space-y-10 pb-24 animate-in fade-in duration-700">
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-5">
            <button 
              onClick={() => setCurrentView('dashboard')}
              className="p-3 bg-white dark:bg-slate-900 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-2xl transition-all shadow-sm group"
            >
              <ChevronRight className="w-6 h-6 rotate-180 text-slate-600 group-hover:text-indigo-600" />
            </button>
            <div>
              <h1 className="text-3xl font-black text-slate-900 dark:text-white">{activeReport.companyName}</h1>
              <div className="flex items-center gap-2 text-slate-400 font-bold text-xs uppercase tracking-widest mt-1">
                <Target className="w-3 h-3" />
                Unqork Discovery Brief
              </div>
            </div>
          </div>
          <button 
            onClick={() => window.print()}
            className="hidden md:flex items-center gap-2 px-6 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl text-sm font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all shadow-sm"
          >
            Export PDF
          </button>
        </div>

        <div className="bg-white dark:bg-slate-900 p-10 md:p-16 rounded-[3rem] border border-slate-100 dark:border-slate-800 shadow-2xl shadow-slate-200/50 dark:shadow-none print:shadow-none print:border-none print:p-0">
          <div className="flex flex-wrap gap-6 mb-16 items-center p-8 bg-slate-50 dark:bg-slate-800/40 rounded-[2rem]">
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 bg-white dark:bg-slate-700 rounded-xl flex items-center justify-center shadow-sm">
                <Clock className="w-5 h-5 text-indigo-500" />
              </div>
              <div>
                <p className="text-[10px] font-black text-slate-400 uppercase tracking-tighter">Research Date</p>
                <p className="text-sm font-bold text-slate-700 dark:text-slate-200">{new Date(activeReport.createdAt).toLocaleDateString()}</p>
              </div>
            </div>
            <div className="h-10 w-px bg-slate-200 dark:bg-slate-700 hidden lg:block" />
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 bg-white dark:bg-slate-700 rounded-xl flex items-center justify-center shadow-sm">
                <Users className="w-5 h-5 text-indigo-500" />
              </div>
              <div>
                <p className="text-[10px] font-black text-slate-400 uppercase tracking-tighter">Stakeholders</p>
                <p className="text-sm font-bold text-slate-700 dark:text-slate-200">{activeReport.linkedinUrls.filter(Boolean).length} Analyzed</p>
              </div>
            </div>
            <div className="h-10 w-px bg-slate-200 dark:bg-slate-700 hidden lg:block" />
            <div className="flex-1 min-w-[200px]">
              <a href={`https://${activeReport.companyUrl}`} target="_blank" className="flex items-center justify-between gap-3 p-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100 dark:shadow-none">
                <span className="text-sm font-bold truncate">{activeReport.companyUrl}</span>
                <ExternalLink className="w-4 h-4 flex-shrink-0" />
              </a>
            </div>
          </div>

          <article className="prose prose-indigo dark:prose-invert max-w-none print:prose-sm">
            {renderMarkdown(activeReport.content)}
          </article>

          {activeReport.sources && activeReport.sources.length > 0 && (
            <div className="mt-20 pt-10 border-t-2 border-slate-50 dark:border-slate-800">
              <h4 className="text-sm font-black text-slate-900 dark:text-white uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
                <Search className="w-5 h-5 text-indigo-500" />
                Verified Research Sources
              </h4>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {activeReport.sources.map((source, idx) => (
                  <a 
                    key={idx}
                    href={source.uri}
                    target="_blank"
                    className="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/40 rounded-2xl hover:bg-white dark:hover:bg-slate-800 hover:shadow-md transition-all border border-transparent hover:border-slate-200 dark:hover:border-slate-700"
                  >
                    <div className="bg-white dark:bg-slate-700 p-2 rounded-lg shadow-sm border border-slate-100 dark:border-slate-600">
                      <ExternalLink className="w-4 h-4 text-indigo-500" />
                    </div>
                    <span className="text-sm font-bold text-slate-600 dark:text-slate-400 line-clamp-1">{source.title || source.uri}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans selection:bg-indigo-100 selection:text-indigo-900">
      <nav className="sticky top-0 z-50 bg-white/70 dark:bg-slate-900/70 backdrop-blur-2xl border-b border-slate-200/50 dark:border-slate-800/50 print:hidden">
        <div className="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
          <div 
            className="flex items-center gap-3 cursor-pointer group"
            onClick={() => setCurrentView('dashboard')}
          >
            <div className="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center transition-transform group-hover:rotate-12">
              <Zap className="w-6 h-6 text-white fill-current" />
            </div>
            <span className="font-black text-2xl tracking-tighter">DiscoveryAI</span>
          </div>
          
          <div className="flex items-center gap-6">
            <div className="hidden sm:flex items-center gap-2 px-4 py-1.5 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 text-xs font-black rounded-full border border-emerald-100 dark:border-emerald-800/50">
              <CheckCircle2 className="w-3.5 h-3.5" />
              GEMINI 2.5 FLASH PREVIEW
            </div>
            <div className="w-10 h-10 rounded-2xl bg-white dark:bg-slate-800 flex items-center justify-center overflow-hidden border-2 border-slate-100 dark:border-slate-700 shadow-sm">
              <Users className="w-5 h-5 text-slate-400" />
            </div>
          </div>
        </div>
      </nav>

      <main className="max-w-7xl mx-auto px-6 py-12">
        {currentView === 'dashboard' && <Dashboard />}
        {currentView === 'new' && <NewReportForm />}
        {currentView === 'report' && <ReportView />}
      </main>

      <footer className="py-20 border-t border-slate-200/50 dark:border-slate-800/50 text-center print:hidden">
        <p className="text-sm font-bold text-slate-400 uppercase tracking-widest">Powered by Gemini 2.5 Flash Deep Research</p>
      </footer>
    </div>
  );
};

export default App;
